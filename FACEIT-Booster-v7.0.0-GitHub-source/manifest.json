{
  "manifest_version": 3,
  "name": "FACEIT Booster",
  "version": "7.0.0",
  "description": "Inline FACEIT matchroom enhancer with team-aware colors, real flags, Elo estimates, player performance, smurf percentage, automation and Discord credit.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.faceit.com/*",
    "https://faceit-booster-api.onrender.com/*",
    "https://flagcdn.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "FACEIT Booster",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.faceit.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "author": "--BANII--S",
  "short_name": "FACEIT Booster"
}
